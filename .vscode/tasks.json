        "compile"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$javac"
      ]
    },
    {
      "label": "Maven: clean package",
      "type": "shell",
      "command": "C:\\tools\\apache-maven-3.9.15\\bin\\mvn.cmd",
      "args": [
        "clean",
        "package"
      ],
      "problemMatcher": [
        "$javac"
      ]
    }
  ]
}
