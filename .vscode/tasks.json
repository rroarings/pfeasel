{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Maven: compile",
      "type": "shell",
      "command": "C:\\tools\\apache-maven-3.9.15\\bin\\mvn.cmd",
      "args": [
        "compile"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$javac"
      ]
    },
    {
      "label": "Maven: clean package",
      "type": "shell",
      "command": "C:\\tools\\apache-maven-3.9.15\\bin\\mvn.cmd",
      "args": [
        "clean",
        "package"
      ],
      "problemMatcher": [
        "$javac"
      ]
    },
    {
      "label": "Kill PF Easel",
      "type": "process",
      "command": "C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "Get-CimInstance Win32_Process | Where-Object { $_.Name -match \"^javaw?\\.exe$\" -and $_.CommandLine -match \"app\\.Main\" -and $_.CommandLine -match \"pfeasel\" } | ForEach-Object { Stop-Process -Id $_.ProcessId -Force -ErrorAction SilentlyContinue }"
      ],
      "problemMatcher": []
    }
  ]
}
